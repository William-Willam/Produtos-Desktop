<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="450.0" prefWidth="720.0"
            style="-fx-background-color: #f4f4f4;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.exemplo.crudprodutos.controller.MainController">
    <top>
        <VBox style="-fx-background-color: #ffffff;
                   -fx-border-color: #dddddd;
                   -fx-border-width: 0 0 1 0;">
            <children>
                <HBox spacing="8.0" alignment="CENTER_LEFT">
                    <padding>
                        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
                    </padding>
                    <children>
                        <TextField fx:id="tfNome"
                                   prefWidth="180.0"
                                   promptText="Nome do produto"
                                   style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6;"/>
                        <TextField fx:id="tfPreco"
                                   prefWidth="90.0"
                                   promptText="Preço"
                                   style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6;"/>
                        <TextField fx:id="tfQuantidade"
                                   prefWidth="90.0"
                                   promptText="Quantidade"
                                   style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6;"/>
                        <TextField fx:id="tfBusca"
                                   prefWidth="150.0"
                                   promptText="🔍 Buscar por nome..."
                                   style="-fx-background-color: #f9f9f9; -fx-border-color: #aaaaaa; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6;"/>
                        <Button fx:id="btnSalvar" text="Salvar" onAction="#salvar"
                                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 14;"/>
                        <Button fx:id="btnExcluir" text="Excluir" onAction="#excluir"
                                style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 14;"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tabela" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn text="ID" prefWidth="50.0">
                    <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Nome" prefWidth="240.0">
                    <cellValueFactory><PropertyValueFactory property="nome"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colunaPreco" text="Preço" prefWidth="120.0">
                    <cellValueFactory><PropertyValueFactory property="preco"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Quantidade" prefWidth="100.0">
                    <cellValueFactory><PropertyValueFactory property="quantidade"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>
    </center>
</BorderPane>